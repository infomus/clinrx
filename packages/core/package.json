{
  "name": "@clinrx/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interactions": {
      "types": "./dist/interactions/index.d.ts",
      "import": "./dist/interactions/index.js"
    },
    "./kg": {
      "types": "./dist/kg/index.d.ts",
      "import": "./dist/kg/index.js"
    },
    "./learning": {
      "types": "./dist/learning/index.d.ts",
      "import": "./dist/learning/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --exclude 'dist/**'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clinrx/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~6.0.3",
    "vitest": "^4.0.14"
  }
}
